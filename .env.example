# eBird API key — get one at https://ebird.org/api/keygen
EBIRD_API_KEY=your_ebird_api_key_here

# Region code — e.g. US, US-CA, US-NY-109
REGION_CODE=US-NY

# How many days back to look (1-30)
DAYS_BACK=1

# Discord webhook URL — create one in Channel Settings > Integrations > Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN
